{
  "manifest_version": 3,
  "name": "Portal Auto Login",
  "version": "1.0.0",
  "description": "Auto Login Extension for Portal",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.app/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["content-portal.js"]
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["config.js", "content-target.js"]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
